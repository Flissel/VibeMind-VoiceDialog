        "finalize_thought": ["TEMPORAL", "LINGUISTIC"]
      }
    },
    "redis": {
      "primary": "MEMORY",
      "secondary": ["TEMPORAL"],
      "description": "In-memory key-value store with expiration support",
      "operations": {
        "set": ["MEMORY"],
        "get": ["MEMORY"],
        "delete": ["MEMORY"],
        "expire": ["MEMORY", "TEMPORAL"],
        "list_keys": ["MEMORY", "LINGUISTIC"],
        "search": ["MEMORY", "LINGUISTIC"]
      }
    },
    "supabase": {
      "primary": "MEMORY",
      "secondary": ["COLLABORATIVE", "TEMPORAL"],
      "description": "PostgreSQL database with real-time collaboration",
      "operations": {
        "select": ["MEMORY", "LINGUISTIC"],
        "insert": ["MEMORY", "TACTILE"],
        "update": ["MEMORY", "TACTILE"],
        "delete": ["MEMORY", "TACTILE"],
        "execute_sql": ["MEMORY", "LINGUISTIC"],
        "subscribe": ["MEMORY", "TEMPORAL", "COLLABORATIVE"]
      }
    },
    "taskmanager": {
      "primary": "MEMORY",
      "secondary": ["TEMPORAL", "COLLABORATIVE"],
      "description": "Task tracking with temporal scheduling",
      "operations": {
        "create_task": ["MEMORY", "TEMPORAL"],
        "update_task": ["MEMORY", "TACTILE"],
        "delete_task": ["MEMORY", "TACTILE"],
        "list_tasks": ["MEMORY", "LINGUISTIC"],
        "get_task": ["MEMORY"]
      }
    },
    "desktop": {
      "primary": "TACTILE",
      "secondary": ["VISUAL", "LINGUISTIC"],
      "description": "Desktop environment control with terminal access",
      "operations": {
        "run_terminal_command": ["TACTILE", "LINGUISTIC"],
        "read_file": ["LINGUISTIC", "MEMORY"],
        "write_file": ["TACTILE", "MEMORY"],
        "list_directory": ["LINGUISTIC", "TACTILE"],
        "get_process_list": ["MEMORY", "LINGUISTIC"],
