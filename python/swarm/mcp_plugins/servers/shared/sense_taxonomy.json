{
  "version": "1.0",
  "description": "Sense-based classification for MCP tools, inspired by human sensory perception",
  "sense_categories": {
    "VISUAL": {
      "description": "Visual perception: screenshots, UI, layout, DOM structure",
      "color": "#4A90E2",
      "icon": "👁️",
      "operations": ["capture", "navigate", "observe", "inspect", "screenshot"],
      "data_types": ["image", "screenshot", "dom", "layout", "pixels"],
      "tools": ["playwright", "desktop"]
    },
    "TACTILE": {
      "description": "Physical manipulation: files, processes, containers, system state",
      "color": "#E67E22",
      "icon": "✋",
      "operations": ["create", "delete", "modify", "move", "execute", "kill", "touch"],
      "data_types": ["file", "process", "container", "binary", "resource"],
      "tools": ["docker", "windows-core", "filesystem", "desktop"]
    },
    "MEMORY": {
      "description": "Storage and retrieval: knowledge graphs, databases, caching",
      "color": "#9B59B6",
      "icon": "🧠",
      "operations": ["store", "retrieve", "update", "query", "associate", "remember", "forget"],
      "data_types": ["entity", "relation", "key-value", "graph", "table", "cache"],
      "tools": ["memory", "redis", "supabase", "taskmanager"]
    },
    "LINGUISTIC": {
      "description": "Text processing: search, retrieval, comprehension, extraction",
      "color": "#27AE60",
      "icon": "📝",
      "operations": ["search", "fetch", "extract", "parse", "summarize", "translate"],
      "data_types": ["text", "html", "markdown", "code", "transcript", "document"],
      "tools": ["fetch", "brave-search", "tavily", "context7", "youtube"]
    },
    "TEMPORAL": {
      "description": "Time-based operations: scheduling, workflows, sequences",
      "color": "#F39C12",
      "icon": "⏰",
      "operations": ["schedule", "sequence", "delay", "trigger", "chain", "timestamp"],
      "data_types": ["timestamp", "duration", "workflow", "event", "cron"],
      "tools": ["time", "n8n", "sequential-thinking"]
    },
    "COLLABORATIVE": {
      "description": "Multi-user interaction: version control, communication, sharing",
      "color": "#E74C3C",
      "icon": "🤝",
      "operations": ["commit", "push", "pull", "review", "comment", "merge", "fork"],
      "data_types": ["repository", "issue", "pr", "commit", "diff", "branch"],
      "tools": ["github"]
    }
  },
  "tool_sense_map": {
    "playwright": {
      "primary": "VISUAL",
      "secondary": ["TACTILE", "LINGUISTIC"],
      "description": "Browser automation with visual perception and DOM manipulation",
      "operations": {
        "browser_navigate": ["VISUAL", "TACTILE"],
        "browser_click": ["VISUAL", "TACTILE"],
        "browser_take_screenshot": ["VISUAL"],
        "browser_snapshot": ["VISUAL"],
        "browser_evaluate": ["VISUAL", "LINGUISTIC"],
        "browser_type": ["TACTILE", "LINGUISTIC"],
        "browser_fill_form": ["TACTILE", "LINGUISTIC"],
        "browser_hover": ["VISUAL", "TACTILE"],
        "browser_drag": ["VISUAL", "TACTILE"],
        "browser_wait_for": ["VISUAL", "TEMPORAL"]
      }
    },
    "memory": {
      "primary": "MEMORY",
      "secondary": ["LINGUISTIC"],
      "description": "Knowledge graph storage with semantic search",
      "operations": {
        "create_entity": ["MEMORY"],
        "create_relation": ["MEMORY"],
        "add_observation": ["MEMORY"],
        "delete_entity": ["MEMORY"],
        "delete_observation": ["MEMORY"],
        "delete_relation": ["MEMORY"],
        "read_graph": ["MEMORY"],
        "search_nodes": ["MEMORY", "LINGUISTIC"],
        "open_nodes": ["MEMORY"]
      }
    },
    "docker": {
      "primary": "TACTILE",
      "secondary": ["MEMORY", "TEMPORAL"],
      "description": "Container lifecycle management and system manipulation",
      "operations": {
        "container_create": ["TACTILE", "MEMORY"],
        "container_start": ["TACTILE", "TEMPORAL"],
        "container_stop": ["TACTILE", "TEMPORAL"],
        "container_remove": ["TACTILE"],
        "container_logs": ["LINGUISTIC", "TEMPORAL"],
        "container_inspect": ["MEMORY", "LINGUISTIC"],
        "image_pull": ["TACTILE", "MEMORY"],
        "image_build": ["TACTILE", "TEMPORAL"]
      }
    },
    "brave-search": {
      "primary": "LINGUISTIC",
      "secondary": [],
      "description": "Privacy-focused web search with text retrieval",
      "operations": {
        "web_search": ["LINGUISTIC"],
        "local_search": ["LINGUISTIC"]
      }
    },
    "filesystem": {
      "primary": "TACTILE",
      "secondary": ["MEMORY", "LINGUISTIC"],
      "description": "File and directory operations with content handling",
      "operations": {
        "read_file": ["LINGUISTIC", "MEMORY"],
        "read_multiple_files": ["LINGUISTIC", "MEMORY"],
        "write_file": ["TACTILE", "MEMORY"],
        "edit_file": ["TACTILE", "LINGUISTIC"],
        "create_directory": ["TACTILE"],
        "list_directory": ["LINGUISTIC", "TACTILE"],
        "move_file": ["TACTILE"],
        "search_files": ["LINGUISTIC", "TACTILE"],
        "get_file_info": ["MEMORY", "TEMPORAL"]
      }
    },
    "github": {
      "primary": "COLLABORATIVE",
      "secondary": ["MEMORY", "LINGUISTIC"],
      "description": "Git repository management and team collaboration",
      "operations": {
        "create_or_update_file": ["COLLABORATIVE", "TACTILE"],
        "create_pull_request": ["COLLABORATIVE", "LINGUISTIC"],
        "create_issue": ["COLLABORATIVE", "LINGUISTIC"],
        "create_repository": ["COLLABORATIVE", "MEMORY"],
        "get_file_contents": ["LINGUISTIC", "MEMORY"],
        "push_files": ["COLLABORATIVE", "TACTILE"],
        "search_code": ["LINGUISTIC", "MEMORY"],
        "search_issues": ["LINGUISTIC", "COLLABORATIVE"]
      }
    },
    "time": {
      "primary": "TEMPORAL",
      "secondary": [],
      "description": "Time operations and timezone conversions",
      "operations": {
        "get_current_time": ["TEMPORAL"],
        "convert_timezone": ["TEMPORAL"],
        "get_timestamp": ["TEMPORAL"],
        "format_time": ["TEMPORAL", "LINGUISTIC"]
      }
    },
    "n8n": {
      "primary": "TEMPORAL",
      "secondary": ["COLLABORATIVE", "TACTILE"],
      "description": "Workflow automation and sequential task execution",
      "operations": {
        "execute_workflow": ["TEMPORAL", "TACTILE"],
