        "search_examples": ["LINGUISTIC", "MEMORY"],
        "get_api_reference": ["LINGUISTIC", "MEMORY"]
      }
    },
    "youtube": {
      "primary": "LINGUISTIC",
      "secondary": ["TEMPORAL", "MEMORY"],
      "description": "Video transcript and caption retrieval",
      "operations": {
        "get_transcript": ["LINGUISTIC", "TEMPORAL"],
        "search_captions": ["LINGUISTIC"],
        "get_video_info": ["MEMORY", "LINGUISTIC"]
      }
    }
  },
  "sense_fusion_patterns": {
    "visual_linguistic": {
      "description": "Screenshot analysis with text extraction (OCR, DOM parsing)",
      "tools": ["playwright", "tavily"],
      "use_cases": ["web scraping", "UI testing", "content extraction", "visual QA"],
      "complexity": "moderate"
    },
    "tactile_memory": {
      "description": "File/system manipulation with persistent state tracking",
      "tools": ["filesystem", "docker", "windows-core", "memory"],
      "use_cases": ["state management", "configuration changes", "deployment tracking"],
      "complexity": "simple"
    },
    "linguistic_memory": {
      "description": "Text retrieval with knowledge storage and semantic search",
      "tools": ["brave-search", "memory", "context7", "tavily"],
      "use_cases": ["research", "knowledge building", "RAG systems", "documentation"],
      "complexity": "moderate"
    },
    "temporal_collaborative": {
      "description": "Workflow automation with team coordination",
      "tools": ["n8n", "github", "taskmanager"],
      "use_cases": ["CI/CD", "automated releases", "notification chains", "project management"],
      "complexity": "complex"
    },
    "tactile_temporal": {
      "description": "System operations with scheduling and timing",
      "tools": ["docker", "n8n", "windows-core"],
      "use_cases": ["cron jobs", "scheduled deployments", "automated maintenance"],
      "complexity": "moderate"
    },
    "visual_tactile": {
      "description": "Visual observation with direct manipulation",
      "tools": ["playwright", "desktop"],
      "use_cases": ["browser automation", "UI automation", "testing"],
      "complexity": "moderate"
    }
  },
  "complexity_levels": {
    "simple": {
      "description": "Single-sense operations with clear inputs/outputs",
      "examples": ["get_current_time", "set_value", "read_file"]
    },
    "moderate": {
      "description": "Two-sense fusion or multi-step single-sense operations",
      "examples": ["browser_navigate + screenshot", "search + store", "workflow execution"]
    },
    "complex": {
      "description": "Three+ sense fusion or sophisticated reasoning required",
      "examples": ["visual QA + knowledge graph", "multi-tool workflows", "adaptive automation"]
    }
  }
}
