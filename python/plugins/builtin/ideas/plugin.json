{
  "id": "ideas",
  "version": "1.0.0",
  "name": "Ideas",
  "description": "Ideen erstellen, verknuepfen, formatieren, explorieren und als Whitepaper exportieren",
  "author": "VibeMind Team",
  "category": "core",
  "changelog": "Initial release",

  "agent_module": "spaces.ideas.agents.ideas_agent",
  "agent_class": "IdeasAgent",
  "agent_factory": "get_ideas_agent",

  "stream": "events:tasks:ideas",
  "event_routes": {
    "idea.list": "events:tasks:ideas",
    "idea.create": "events:tasks:ideas",
    "idea.update": "events:tasks:ideas",
    "idea.delete": "events:tasks:ideas",
    "idea.find": "events:tasks:ideas",
    "idea.connect": "events:tasks:ideas",
    "idea.auto_link": "events:tasks:ideas",
    "idea.add_image": "events:tasks:ideas",
    "idea.current_space": "events:tasks:ideas",
    "idea.format_table": "events:tasks:ideas",
    "idea.summarize": "events:tasks:ideas",
    "idea.whitepaper": "events:tasks:ideas",
    "idea.white_paper": "events:tasks:ideas",
    "idea.expand": "events:tasks:ideas",
    "idea.explain": "events:tasks:ideas",
    "idea.analyze_links": "events:tasks:ideas",
    "idea.format_note": "events:tasks:ideas",
    "idea.format_action_list": "events:tasks:ideas",
    "idea.format_pros_cons": "events:tasks:ideas",
    "idea.format_hierarchy": "events:tasks:ideas",
    "idea.format_specs": "events:tasks:ideas",
    "idea.convert_format": "events:tasks:ideas",
    "idea.list_formats": "events:tasks:ideas",
    "idea.format_revert": "events:tasks:ideas",
    "idea.explore.start": "events:tasks:ideas",
    "idea.explore.stop": "events:tasks:ideas",
    "idea.explore.status": "events:tasks:ideas",
    "idea.explore.accept": "events:tasks:ideas",
    "idea.explore.reject": "events:tasks:ideas",
    "idea.explore.depth": "events:tasks:ideas",
    "idea.explore.visualize": "events:tasks:ideas",
    "idea.explore.continue": "events:tasks:ideas",
    "idea.explore.direction": "events:tasks:ideas",
    "idea.explore.respond": "events:tasks:ideas",
    "idea.generate_doc": "events:tasks:ideas"
  },

  "classifier_hints": {
    "keywords_de": ["idee", "notiz", "verlinke", "formatiere", "whitepaper", "exploriere"],
    "keywords_en": ["idea", "note", "link", "format", "whitepaper", "explore"],
    "example_utterances": [
      {"text": "Notiere: API Design", "event_type": "idea.create"},
      {"text": "Zeig alle Ideen", "event_type": "idea.list"},
      {"text": "Verlinke die Ideen sinnvoll", "event_type": "idea.auto_link"},
      {"text": "Formatiere in Aktionslisten", "event_type": "idea.format_action_list"}
    ]
  },

  "builtin": true,
  "env_flag": null,
  "dependencies": []
}
