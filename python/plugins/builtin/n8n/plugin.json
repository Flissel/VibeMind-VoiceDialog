{
  "id": "n8n",
  "version": "1.0.0",
  "name": "N8n Workflow Builder",
  "description": "N8n-Workflows erstellen, verwalten, aktivieren und ausfuehren per Voice",
  "author": "VibeMind Team",
  "category": "automation",
  "changelog": "Initial release",

  "agent_module": "spaces.n8n.agents.n8n_agent",
  "agent_class": "N8nBackendAgent",
  "agent_factory": "get_n8n_agent",

  "stream": "events:tasks:n8n",
  "event_routes": {
    "n8n.generate": "events:tasks:n8n",
    "n8n.list": "events:tasks:n8n",
    "n8n.status": "events:tasks:n8n",
    "n8n.activate": "events:tasks:n8n",
    "n8n.deactivate": "events:tasks:n8n",
    "n8n.delete": "events:tasks:n8n",
    "n8n.execute": "events:tasks:n8n",
    "n8n.describe": "events:tasks:n8n"
  },

  "classifier_hints": {
    "keywords_de": ["workflow", "n8n", "automatisierung"],
    "keywords_en": ["workflow", "n8n", "automation"],
    "example_utterances": [
      {"text": "Erstelle einen Workflow fuer X", "event_type": "n8n.generate"},
      {"text": "Zeig alle Workflows", "event_type": "n8n.list"},
      {"text": "Aktiviere Workflow Y", "event_type": "n8n.activate"},
      {"text": "N8n Status", "event_type": "n8n.status"}
    ]
  },

  "builtin": true,
  "env_flag": "N8N_ENABLED",
  "dependencies": []
}
