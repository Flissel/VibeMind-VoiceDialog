{
  "id": "schedule",
  "version": "1.0.0",
  "name": "Schedule",
  "description": "Erinnerungen, Alarme und Zeitplaene mit APScheduler",
  "author": "VibeMind Team",
  "category": "productivity",
  "changelog": "Initial release",

  "agent_module": "spaces.schedule.agents.schedule_agent",
  "agent_class": "ScheduleBackendAgent",
  "agent_factory": "get_schedule_agent",

  "stream": "events:tasks:schedule",
  "event_routes": {
    "schedule.create": "events:tasks:schedule",
    "schedule.list": "events:tasks:schedule",
    "schedule.cancel": "events:tasks:schedule",
    "schedule.modify": "events:tasks:schedule",
    "schedule.status": "events:tasks:schedule",
    "schedule.snooze": "events:tasks:schedule"
  },

  "classifier_hints": {
    "keywords_de": ["erinnerung", "alarm", "zeitplan", "termin", "schedule"],
    "keywords_en": ["reminder", "alarm", "schedule", "appointment"],
    "example_utterances": [
      {"text": "Erinnere mich morgen um 9", "event_type": "schedule.create"},
      {"text": "Zeig meine Termine", "event_type": "schedule.list"}
    ]
  },

  "builtin": true,
  "env_flag": "SCHEDULE_ENABLED",
  "dependencies": []
}
