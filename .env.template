# Voice Dialog Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ElevenLabs API Key (REQUIRED - for conversational AI agent)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ElevenLabs Agent ID (REQUIRED - create agent at elevenlabs.io)
# Get your agent ID from: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=your_agent_id_here

# OpenAI API Key (OPTIONAL - fallback for additional features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Logging Configuration (optional)
LOG_LEVEL=INFO
LOG_FILE=voice_dialog.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
