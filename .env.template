# Voice Dialog Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# MULTI-AGENT VOICE SYSTEM
# ============================================================================

# ElevenLabs API Key (REQUIRED)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Multi-Agent ElevenLabs Agent IDs (REQUIRED)
# Create 4 agents at: https://elevenlabs.io/app/conversational-ai
# See python/setup_agents.py for agent configuration details

# Entry point agent - learns user preferences and routes requests
AGENT_CONVERSATIONAL_MEMORY=your_agent_id_1

# Manages projects and delegates tasks
AGENT_PROJECT_MANAGER=your_agent_id_2

# Executes desktop automation
AGENT_DESKTOP_WORKER=your_agent_id_3

# Writes code and documentation
AGENT_PROJECT_WRITER=your_agent_id_4

# ============================================================================
# SUPERMEMORY (REQUIRED - for context preservation across agents)
# ============================================================================
# Get your key from: https://supermemory.ai/
SUPERMEMORY_API_KEY=your_supermemory_key_here

# ============================================================================
# LLM PROVIDERS (at least one required)
# ============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter API Key (supports multiple LLMs)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================================
# DESKTOP AUTOMATION (OPTIONAL - connect to your desktop automation API)
# ============================================================================
DESKTOP_AUTOMATION_HOST=localhost
DESKTOP_AUTOMATION_PORT=8000

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=voice_dialog.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# LEGACY (for backwards compatibility with single-agent voice_dialog_main.py)
# ============================================================================
ELEVENLABS_AGENT_ID=your_legacy_agent_id_here
