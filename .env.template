# Voice Dialog Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# MULTI-AGENT VOICE SYSTEM
# ============================================================================

# ElevenLabs API Key (REQUIRED)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Multi-Agent ElevenLabs Agent IDs (REQUIRED)
# Create 4 agents at: https://elevenlabs.io/app/conversational-ai
# See python/setup_agents.py for agent configuration details

# Entry point agent - learns user preferences and routes requests
AGENT_CONVERSATIONAL_MEMORY=your_agent_id_1

# Manages projects and delegates tasks
AGENT_PROJECT_MANAGER=your_agent_id_2

# Executes desktop automation
AGENT_DESKTOP_WORKER=your_agent_id_3

# Writes code and documentation
AGENT_PROJECT_WRITER=your_agent_id_4

# Coordinates complex tasks using Claude Opus 4.5 with extended thinking
# Uses OpenRouter for reasoning capabilities
AGENT_CLAUDE_COORDINATOR=your_agent_id_5

# ============================================================================
# CLAUDE ORCHESTRATOR (OPTIONAL - for delegating tasks to Claude Code instances)
# ============================================================================
# Redis connection for task queue (default: localhost:6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenRouter model for ClaudeCoordinator reasoning
# Recommended: anthropic/claude-opus-4 for extended thinking
OPENROUTER_MODEL=anthropic/claude-opus-4

# ============================================================================
# SUPERMEMORY (REQUIRED - for context preservation across agents)
# ============================================================================
# Get your key from: https://supermemory.ai/
SUPERMEMORY_API_KEY=your_supermemory_key_here

# ============================================================================
# LLM PROVIDERS (at least one required)
# ============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter API Key (supports multiple LLMs)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================================
# DESKTOP AUTOMATION (OPTIONAL - connect to your desktop automation API)
# ============================================================================
DESKTOP_AUTOMATION_HOST=localhost
DESKTOP_AUTOMATION_PORT=8000

# ============================================================================
# AUDIO CONFIGURATION (prevents feedback loop)
# ============================================================================

# Microphone amplitude threshold (0.0 to 1.0)
# Higher = only louder sounds captured (user voice close to mic)
# Lower = more sensitive, captures quieter sounds too
# Default: 0.03 (3%) - adjust if speakers trigger microphone
AUDIO_THRESHOLD=0.03

# Minimum speech duration (seconds)
# How long continuous speech must last before triggering
# Default: 0.3 seconds (300ms)
MIN_SPEECH_DURATION=0.3

# Enable/disable threshold filtering
# Set to false to use default audio capture (may cause feedback loop)
# Default: true (recommended)
USE_THRESHOLD_FILTERING=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=voice_dialog.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# LEGACY (for backwards compatibility with single-agent voice_dialog_main.py)
# ============================================================================
ELEVENLABS_AGENT_ID=your_legacy_agent_id_here
