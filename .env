# Voice Dialog API Keys
# IMPORTANT: This file should NEVER be committed to version control
# See .env.template for configuration options

# OpenAI API Key (required for AI agent responses)
# SECURITY WARNING: Your previous key was exposed. Please:
# 1. Go to https://platform.openai.com/api-keys
# 2. Revoke the old key
# 3. Generate a new key
# 4. Add it here
OPENAI_API_KEY=

# ElevenLabs API Key (optional - for TTS voice output)
ELEVENLABS_API_KEY=

# Auto-start MoireTracker on launch (default: false for robustness)
# Toggle by clicking the visual circle, or set manually here
# AUTO_START_MOIRE=false

# Auto-start MoireTracker on launch
AUTO_START_MOIRE=true
