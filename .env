# ============================================================================
# AUDIO CONFIGURATION (prevents feedback loop)
# ============================================================================

# Microphone amplitude threshold (0.0 to 1.0)
# Higher = only louder sounds captured (user voice close to mic)
# Lower = more sensitive, captures quieter sounds too
# Default: 0.03 (3%) - adjust if speakers trigger microphone
AUDIO_THRESHOLD=0.03

# Minimum speech duration (seconds)
# How long continuous speech must last before triggering
# Default: 0.3 seconds (300ms)
MIN_SPEECH_DURATION=0.3

# Enable/disable threshold filtering
# Set to false to use default audio capture (may cause feedback loop)
# Default: true (recommended)
USE_THRESHOLD_FILTERING=true