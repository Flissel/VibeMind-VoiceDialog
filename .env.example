# =============================================================================
# VibeMind Voice Dialog Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# VOICE PROVIDER SELECTION
# =============================================================================

# Voice provider: "openai_realtime" or "elevenlabs"
# - openai_realtime: OpenAI Realtime API (speech-to-speech, ~300ms latency, native function calling)
# - elevenlabs: ElevenLabs Conversational AI (legacy, requires ELEVENLABS_API_KEY + AGENT_MULTIVERSE)
VOICE_PROVIDER=elevenlabs

# =============================================================================
# OPENAI REALTIME API (when VOICE_PROVIDER=openai_realtime)
# =============================================================================

# OpenAI API Key (required for Realtime voice)
# OPENAI_API_KEY=sk-...

# Realtime model (default: gpt-4o-realtime-preview)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Voice for Realtime (default: alloy)
# Options: alloy, ash, ballad, coral, echo, sage, shimmer, verse
OPENAI_REALTIME_VOICE=alloy

# =============================================================================
# ELEVENLABS VOICE DIALOG (when VOICE_PROVIDER=elevenlabs)
# =============================================================================

# ElevenLabs API Key (required for ElevenLabs voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Agent IDs for different agents
AGENT_MULTIVERSE=your_agent_id_for_rachel
ELEVENLABS_AGENT_ID=fallback_agent_id

# =============================================================================
# VOICE BRIDGE V2 (New Async Architecture)
# =============================================================================

# Enable VoiceBridgeV2 with NotificationQueue for deferred feedback
# When enabled:
# - Rachel only sends user intent (no direct tool execution)
# - Backend agents execute tools asynchronously
# - Results are delivered on next user input via NotificationQueue
# - Works with both OpenAI Realtime and ElevenLabs providers
USE_VOICE_BRIDGE_V2=false

# =============================================================================
# VNC LIVE PREVIEW CONFIGURATION
# =============================================================================
# These settings control how VNC preview URLs are generated

# Option 1: Cloud Production (Reverse Proxy with HTTPS)
# --------------------------------------------------------
# Set VNC_BASE_URL to use a reverse proxy
# URL format: {VNC_BASE_URL}/{project_id}
# Example: https://preview.vibemind.io/vnc/proj-abc123
#
# VNC_BASE_URL=https://preview.vibemind.io/vnc

# Option 2: Remote Server (Direct Connection)
# --------------------------------------------------------
# Set VNC_HOST to the IP or hostname of your server
# URL format: http://{VNC_HOST}:{port}/vnc.html
# Example: http://192.168.1.100:6080/vnc.html
#
# VNC_HOST=192.168.1.100

# Option 3: Local Development (Default)
# --------------------------------------------------------
# If neither VNC_BASE_URL nor VNC_HOST is set, localhost is used
# URL format: http://localhost:{port}/vnc.html
# Example: http://localhost:6080/vnc.html

# =============================================================================
# CODING ENGINE INTEGRATION
# =============================================================================

# Path to Coding Engine installation (optional, auto-detected)
# CODING_ENGINE_PATH=C:\Users\User\Desktop\Coding_engine

# =============================================================================
# DATABASE (Supabase)
# =============================================================================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key
SUPABASE_KEY=your_supabase_anon_key

# =============================================================================
# REQ-ORCHESTRATOR INTEGRATION (Shuttle Pipeline)
# =============================================================================

# URL of the req-orchestrator service
REQ_ORCHESTRATOR_URL=http://localhost:8087

# Score threshold for passing validation (0.0 - 1.0)
REQ_SCORE_THRESHOLD=0.7

# Enable individual pipeline stages (set to "true" to enable API calls)
# When disabled, stages are skipped but still broadcast for visualization
USE_KG_API=false
USE_TECHSTACK_API=false

# =============================================================================
# OPENROUTER (LLM for summarization/generation)
# =============================================================================

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model for RAG Intent Classification (via OpenRouter)
# Default: openai/gpt-4o (best quality, ~$5/1M tokens)
# Options: openai/gpt-4o, openai/o1, anthropic/claude-sonnet-4, etc.
# See https://openrouter.ai/models for available models
RAG_CLASSIFIER_MODEL=openai/gpt-4o

# =============================================================================
# SUPERMEMORY (Semantic Memory for Intent Classification)
# =============================================================================

# Supermemory API Key for RAG-based intent classification
SUPERMEMORY_API_KEY=your_supermemory_api_key_here

# Enable RAG-based intent classification (uses Supermemory for semantic search)
# When enabled, replaces keyword-based rules with semantic similarity search
USE_RAG_CLASSIFIER=true

# =============================================================================
# SUPERMEMORY SERVICES (System-wide Task Memory)
# =============================================================================

# Enable Task Memory Service (tracks executed tasks in Supermemory)
# Allows queries like "Was habe ich heute gemacht?"
USE_TASK_MEMORY=true

# Enable Conversation Memory Service (stores conversations for cross-session context)
# Allows queries like "Was haben wir letztens besprochen?"
USE_CONVERSATION_MEMORY=true

# Enable User Profile Service (learns user preferences and habits)
# Tracks most used commands and preferred formats
USE_USER_PROFILES=true

# =============================================================================
# PERFORMANCE
# =============================================================================

# Fast Startup Mode (default: true)
# When enabled, skips Supermemory API calls during initialization
# This reduces startup time from 30+ seconds to <1 second
# Intent classification uses local word-overlap matching instead
FAST_STARTUP=true

# Force synchronous mode (no Redis/backend agents)
# When enabled, tools execute directly without Redis queue
# Useful for debugging or when Redis is not available
FORCE_SYNC_MODE=true

# =============================================================================
# BROADCAST MODE (Fan-Out Architecture)
# =============================================================================

# Enable Broadcast Fan-Out mode for intent execution
# When enabled, every classified intent is broadcast to ALL domain agents:
# - The responsible agent executes the tool
# - Non-responsible agents analyze the intent for user profiling
# - Profiling insights are uploaded to Supermemory asynchronously
# Requires: Supermemory for profiling storage (graceful degradation without)
USE_BROADCAST_MODE=false

# =============================================================================
# DROPE REFERENCE RESOLUTION
# =============================================================================

# Enable DroPE-based reference resolution for ambiguous utterances
# Resolves "das", "nochmal", "es" using conversation history context
# Requires: torch, transformers, accelerate
USE_DROPE_RESOLVER=false

# DroPE model to use (default: smallest/fastest)
# Options:
#   SakanaAI/DroPE-SmolLM-135M-32K (135M params, ~100ms, CPU-friendly)
#   SakanaAI/DroPE-SmolLM-360M-32K (360M params, ~200ms)
#   SakanaAI/DroPE-LLaMA-2-7B-32K (7B params, GPU recommended)
DROPE_MODEL=SakanaAI/DroPE-SmolLM-135M-32K

# =============================================================================
# ROARBOOT SPACE (Rowboat Knowledge Graph — native BrowserView)
# =============================================================================
# Rowboat runs natively in VibeMind (no Docker needed).
# LLM provider is auto-configured from the API keys above.
# Priority: OPENROUTER_API_KEY > OPENAI_API_KEY > ANTHROPIC_API_KEY
# You can also configure the provider manually in Roarboot Settings.

# Override the default LLM model for Rowboat (optional)
# ROWBOAT_MODEL=anthropic/claude-sonnet-4

# Auto-update check interval in seconds (default: 6 hours)
# ROWBOAT_UPDATE_CHECK_INTERVAL=21600

# Publish space metadata to Rowboat knowledge graph (~/.rowboat/)
# When enabled, Ideas/SWE Design/Arch-Team/Coding publish manifests
# and knowledge notes that the Graph Builder auto-indexes.
ROWBOAT_PUBLISH_ENABLED=true

# =============================================================================
# RESEARCH SPACE (ZeroClaw — Web Research Engine)
# =============================================================================
# ZeroClaw runs as a subprocess (Rust binary) providing web research,
# scraping, and summarization. Results flow back as Ideas or to Rowboat.
# Install: cargo install zeroclaw  OR  cd external/zeroclaw && cargo build --release

# Enable ZeroClaw Research Space
USE_ZEROCLAW=false

# Path to zeroclaw binary (default: searches PATH and external/zeroclaw)
# ZEROCLAW_BINARY=zeroclaw

# Gateway port (default: 42618)
# ZEROCLAW_PORT=42618

# Optional: custom config for ZeroClaw
# ZEROCLAW_CONFIG_PATH=python/swarm/zeroclaw/config.toml

# =============================================================================
# MINIBOOK SPACE (Inter-Space Collaboration)
# =============================================================================
# Minibook enables multi-space collaboration via agent discussions.
# Each VibeMind space registers as a Minibook agent with a role.
# Multi-space tasks are posted as discussions with @mentions.
# Install: https://github.com/c4pt0r/minibook

# Enable Minibook inter-space collaboration
MINIBOOK_ENABLED=false

# Minibook API URL (default: http://localhost:3480)
# MINIBOOK_URL=http://localhost:3480

# Auto-register VibeMind spaces as Minibook agents on startup
MINIBOOK_AUTO_REGISTER=true

# Polling interval for collaboration responses (seconds)
# MINIBOOK_POLL_INTERVAL=2.0

# Timeout for multi-space collaboration (seconds)
# MINIBOOK_COLLABORATION_TIMEOUT=120.0

# --- MinibookHub (Central Execution) ---
# When enabled, ALL intents route through Minibook instead of direct execution.
# Requires MINIBOOK_ENABLED=true and a running Minibook Docker instance.
# Falls back to direct execution when Minibook is unreachable.
USE_MINIBOOK_HUB=false

# Timeout for single-space sync-wait (seconds, default: 10)
# MINIBOOK_HUB_SYNC_TIMEOUT=10

# Timeout for multi-space async-poll (seconds, default: 120)
# MINIBOOK_HUB_ASYNC_TIMEOUT=120

# LLM model for SpaceRouter (via OpenRouter, default: openai/gpt-4o-mini)
# MINIBOOK_ENRICHMENT_MODEL=openai/gpt-4o-mini

# Enable LLM-based routing (false = keyword-only fallback)
# MINIBOOK_ENRICHMENT_LLM=true

# Enable Rachel prompt metadata (agent status, tasks in system prompt)
# MINIBOOK_RACHEL_PROMPT=true

# =============================================================================
# SCHEDULE SPACE (Erinnerungen, Alarme, geplante Aufgaben)
# =============================================================================
# Install: pip install APScheduler>=3.10.0

# Enable the Schedule Space (APScheduler-based task scheduling)
SCHEDULE_ENABLED=false

# Default timezone for scheduled tasks
# SCHEDULE_TIMEZONE=Europe/Berlin

# Maximum concurrent APScheduler jobs
# SCHEDULE_MAX_CONCURRENT=5

# Misfire grace time in seconds (how late a job can fire after its scheduled time)
# SCHEDULE_MISFIRE_GRACE=60

# =============================================================================
# DEBUGGING
# =============================================================================

# Enable debug mode (verbose logging)
DEBUG=true